{
  "entities": {
    "users": {
      "title": "User Profiles",
      "description": "Student user profile information and academic target settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string" },
        "university": { "type": "string" },
        "major": { "type": "string" },
        "year": { "type": "string" },
        "gpaGoal": { "type": "number" },
        "targetRole": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "studySuites": {
      "title": "AI Study Suites",
      "description": "Generated course notes, quizzes, flashcards, and mindmaps.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "summary": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "title"]
    },
    "assignments": {
      "title": "Student Assignments",
      "description": "Course assignments and step-by-step AI solutions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "dueDate": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "userId", "title"]
    },
    "attendance": {
      "title": "Subject Attendance",
      "description": "Attendance tracking per course subject.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "totalClasses": { "type": "number" },
        "attendedClasses": { "type": "number" }
      },
      "required": ["id", "userId", "code"]
    },
    "schedules": {
      "title": "Smart Calendar Events",
      "description": "Class schedule, study sessions, and interviews.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" }
      },
      "required": ["id", "userId", "title"]
    },
    "dsaProblems": {
      "title": "DSA Practice Items",
      "description": "Coding hub problems solved and bookmarked by student.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "solved": { "type": "boolean" },
        "bookmarked": { "type": "boolean" }
      },
      "required": ["id", "userId", "title"]
    },
    "codingCourses": {
      "title": "Coding Courses",
      "description": "Full coding course catalog, modules, lessons, code snippets, and capstones.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string" },
        "badge": { "type": "string" },
        "description": { "type": "string" },
        "instructor": { "type": "object" },
        "level": { "type": "string" },
        "durationHours": { "type": "number" },
        "totalModules": { "type": "number" },
        "rating": { "type": "number" },
        "enrolledStudentsCount": { "type": "number" },
        "tags": { "type": "array" },
        "gradientBg": { "type": "string" },
        "modules": { "type": "array" },
        "capstoneProject": { "type": "object" }
      },
      "required": ["id", "title", "category"]
    },
    "userCourseProgress": {
      "title": "User Course Progress",
      "description": "Tracks student enrollment and completed lesson IDs per course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "completedLessonIds": { "type": "array" },
        "lastAccessedAt": { "type": "string" },
        "enrolledAt": { "type": "string" }
      },
      "required": ["id", "userId", "courseId"]
    },
    "certificates": {
      "title": "Issued Certificates",
      "description": "Certificates granted upon 100% completion of coding courses.",
      "type": "object",
      "properties": {
        "certificateId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "joinedAt": { "type": "string" },
        "userPlan": { "type": "string" },
        "courseId": { "type": "string" },
        "courseTitle": { "type": "string" },
        "issuedAt": { "type": "string" },
        "attendancePercentage": { "type": "number" },
        "totalClassesAttended": { "type": "number" },
        "totalClassesHeld": { "type": "number" },
        "dsaSolvedCount": { "type": "number" }
      },
      "required": ["certificateId", "userId", "courseId", "courseTitle", "userName"]
    }
  },
  "securityRules": {
    "users": {
      "read": "true",
      "write": "true"
    },
    "codingCourses": {
      "read": "true",
      "write": "true"
    },
    "userCourseProgress": {
      "read": "true",
      "write": "true"
    },
    "certificates": {
      "read": "true",
      "write": "true"
    },
    "studySuites": {
      "read": "auth != null && auth.uid == resource.data.userId",
      "write": "auth != null && auth.uid == request.resource.data.userId"
    },
    "assignments": {
      "read": "auth != null && auth.uid == resource.data.userId",
      "write": "auth != null && auth.uid == request.resource.data.userId"
    },
    "attendance": {
      "read": "auth != null && auth.uid == resource.data.userId",
      "write": "auth != null && auth.uid == request.resource.data.userId"
    },
    "schedules": {
      "read": "auth != null && auth.uid == resource.data.userId",
      "write": "auth != null && auth.uid == request.resource.data.userId"
    },
    "dsaProblems": {
      "read": "auth != null && auth.uid == resource.data.userId",
      "write": "auth != null && auth.uid == request.resource.data.userId"
    }
  }
}
